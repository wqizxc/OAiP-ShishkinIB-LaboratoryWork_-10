<Window x:Class="laba_10.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2196F3" CornerRadius="0,0,30,30">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Система авторизации" FontSize="25" 
                           Foreground="#E3F2FD" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Форма входа -->
        <StackPanel Grid.Row="1" Margin="30,20">
            <TextBlock Text="Email" FontSize="12" Foreground="#757575" Margin="0,0,0,5"/>
            <TextBox x:Name="EmailBox" Height="40" FontSize="14" 
                     BorderBrush="#BDBDBD" BorderThickness="0,0,0,2"
                     Margin="0,0,0,20">
                <TextBox.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>

            <TextBlock Text="Пароль" FontSize="12" Foreground="#757575" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PassBox" Height="40" FontSize="14"
                         BorderBrush="#BDBDBD" BorderThickness="0,0,0,2"
                         Margin="0,0,0,20"/>

            <Button Content="ВОЙТИ" Click="Login_Click" Height="45" 
                    Background="#2196F3" Foreground="White"
                    FontSize="14" FontWeight="Bold"
                    BorderThickness="0" Margin="0,0,0,10"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="25"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="Забыли пароль?" Click="Recovery_Click" 
                    Background="Transparent" Foreground="#2196F3"
                    BorderThickness="0" Margin="0,0,0,10"
                    Cursor="Hand" FontSize="12"/>

            <Button Content="Создать аккаунт" Click="Register_Click" 
                    Background="#4CAF50" Foreground="White"
                    FontSize="14" FontWeight="Bold"
                    BorderThickness="0" Height="45"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="25"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>