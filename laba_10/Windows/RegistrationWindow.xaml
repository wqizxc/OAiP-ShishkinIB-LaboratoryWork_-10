<Window x:Class="laba_10.Windows.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация фотографа" Height="750" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text=" Регистрация фотографа" 
                       FontSize="22" FontWeight="Bold" 
                       Foreground="#2196F3" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,25"/>

            <StackPanel Grid.Row="1" Margin="0,0,0,20">
                <!-- Имя и Фамилия в одну строку -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Имя *" FontSize="11" Foreground="#757575" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtFirstName" Height="38" FontSize="13"
                                 BorderBrush="#E0E0E0" BorderThickness="0,0,0,2"
                                 ToolTip="Введите ваше имя (2-50 букв)"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Фамилия *" FontSize="11" Foreground="#757575" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtLastName" Height="38" FontSize="13"
                                 BorderBrush="#E0E0E0" BorderThickness="0,0,0,2"
                                 ToolTip="Введите вашу фамилию (2-50 букв)"/>
                    </StackPanel>
                </Grid>

                <!-- Дата рождения и Телефон -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Дата рождения *" FontSize="11" Foreground="#757575" Margin="0,0,0,5"/>
                        <DatePicker x:Name="DPBirth" Height="38" FontSize="13"
                                    BorderBrush="#E0E0E0" BorderThickness="0,0,0,2"
                                    SelectedDateFormat="Short"
                                    ToolTip="Вам должно быть от 14 до 120 лет"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Телефон *" FontSize="11" Foreground="#757575" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtPhone" Height="38" FontSize="13"
                                 BorderBrush="#E0E0E0" BorderThickness="0,0,0,2"
                                 ToolTip="Введите номер (10-12 цифр, например: +79991234567)"/>
                    </StackPanel>
                </Grid>

                <!-- Email -->
                <TextBlock Text="Email *" FontSize="11" Foreground="#757575" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtEmail" Height="38" FontSize="13"
                         BorderBrush="#E0E0E0" BorderThickness="0,0,0,2"
                         Margin="0,0,0,15"
                         ToolTip="Введите корректный email (пример: name@domain.com)"/>

                <!-- Направление -->
                <TextBlock Text="Направление фотографии *" FontSize="11" Foreground="#757575" Margin="0,0,0,5"/>
                <TextBox x:Name="TxtDirection" Height="38" FontSize="13"
                         BorderBrush="#E0E0E0" BorderThickness="0,0,0,2"
                         Margin="0,0,0,15"
                         ToolTip="Например: портретная, пейзажная, репортажная"/>

                <!-- Дата первой публикации -->
                <TextBlock Text="Дата первой публикации *" FontSize="11" Foreground="#757575" Margin="0,0,0,5"/>
                <DatePicker x:Name="DPPub" Height="38" FontSize="13"
                            BorderBrush="#E0E0E0" BorderThickness="0,0,0,2"
                            SelectedDateFormat="Short"
                            Margin="0,0,0,15"
                            ToolTip="Дата не может быть в будущем"/>

                <!-- Пароль -->
                <TextBlock Text="Пароль *" FontSize="11" Foreground="#757575" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PBPass" Height="38" FontSize="13"
                             BorderBrush="#E0E0E0" BorderThickness="0,0,0,2"
                             Margin="0,0,0,20"
                             ToolTip="Минимум 6 символов, должен содержать буквы и цифры"/>

                <!-- Чекбокс админа -->
                <CheckBox x:Name="IsAdmin" Content="Зарегистрировать как администратор" 
                          FontSize="12" Foreground="#424242"
                          Margin="0,0,0,20"/>

                <!-- Кнопка регистрации -->
                <Button Content="ЗАРЕГИСТРИРОВАТЬСЯ" Click="Register_Click" 
                        Height="45" Background="#4CAF50" Foreground="White"
                        FontSize="14" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="25"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <!-- Подсказка -->
                <TextBlock Text="* - обязательные поля" 
                           FontSize="10" Foreground="#9E9E9E"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>