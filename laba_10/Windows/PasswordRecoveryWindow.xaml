<Window x:Class="laba_10.Windows.PasswordRecoveryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Восстановление пароля" Height="400" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text=" Восстановление пароля" 
                   FontSize="20" FontWeight="Bold" 
                   Foreground="#2196F3" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,25"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Email" FontSize="12" Foreground="#757575" Margin="0,0,0,5"/>
            <TextBox x:Name="EmailBox" Height="40" FontSize="14"
                     BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                     Margin="0,0,0,15"/>

            <Button Content="Отправить код" Click="SendCode_Click" 
                    Height="40" Background="#2196F3" Foreground="White"
                    FontSize="13" FontWeight="Bold"
                    BorderThickness="0" Margin="0,0,0,15"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <TextBlock Text="Код из письма" FontSize="12" Foreground="#757575" Margin="0,0,0,5"/>
            <TextBox x:Name="CodeBox" Height="40" FontSize="14"
                     BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                     Margin="0,0,0,15"/>

            <TextBlock Text="Новый пароль" FontSize="12" Foreground="#757575" Margin="0,0,0,5"/>
            <PasswordBox x:Name="NewPassBox" Height="40" FontSize="14"
                         BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                         Margin="0,0,0,20"/>

            <Button Content="Сменить пароль" Click="ChangePassword_Click" 
                    Height="45" Background="#4CAF50" Foreground="White"
                    FontSize="14" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="25"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>