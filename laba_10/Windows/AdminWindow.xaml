<Window x:Class="laba_10.Windows.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Панель администратора" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2196F3" CornerRadius="10" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text=" Панель администратора" FontSize="24" FontWeight="Bold" 
                               Foreground="White"/>
                    <TextBlock x:Name="AdminName" Text="Администратор" FontSize="14" 
                               Foreground="#E3F2FD" Margin="0,5,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Content="Выйти" Click="Logout_Click" 
                        Background="#FF5252" Foreground="White"
                        Padding="20,10" FontSize="14"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15">
            <DataGrid x:Name="UsersGrid" AutoGenerateColumns="False" 
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      SelectionMode="Single" GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column" RowHeight="45"
                      Background="White" BorderBrush="#E0E0E0">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#2196F3"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,8"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="120"/>
                    <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="120"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding PhoneNumber}" Width="130"/>
                    <DataGridTextColumn Header="Направление" Binding="{Binding PhotographyDirection}" Width="150"/>
                    <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="➕ Добавить" Click="AddUser_Click" 
                    Background="#4CAF50" Foreground="White"
                    Padding="25,12" FontSize="14" FontWeight="Bold"
                    BorderThickness="0" Margin="0,0,10,0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="🗑️ Удалить" Click="DeleteUser_Click" 
                    Background="#F44336" Foreground="White"
                    Padding="25,12" FontSize="14" FontWeight="Bold"
                    BorderThickness="0" Margin="0,0,10,0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="🔄 Обновить" Click="Refresh_Click" 
                    Background="#9C27B0" Foreground="White"
                    Padding="25,12" FontSize="14" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>